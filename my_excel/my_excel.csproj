<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
	  <UseWPF>true</UseWPF>
	  <ApplicationIcon>assets\MainWindow.ico</ApplicationIcon>
  </PropertyGroup>

	<ItemGroup>
		<None Remove="assets/mainwindow.ico" />
	</ItemGroup>

	<ItemGroup>
	  <Content Include="assets\MainWindow.ico" />
	</ItemGroup>
	<ItemGroup>
		<Resource Include="assets/mainwindow.ico" />
	</ItemGroup>

</Project>
