<UserControl x:Class="my_excel.View.UserControls.TopMenuBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:my_excel.View.UserControls"
             mc:Ignorable="d" 
             Height="25" d:DesignWidth="800">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>
        <Menu>
            <MenuItem Header="File" FontSize="16">
                <Button Name="New"></Button>
                <Button Name="Open"></Button>
                <Button Name="Quit"></Button>
            </MenuItem>
            <MenuItem Header="Help" FontSize="16">
                <Button Name="About"></Button>
            </MenuItem>
        </Menu>
    </Grid>
</UserControl>
